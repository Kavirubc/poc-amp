[req]
default_bits = 2048
prompt = no
default_md = sha256
req_extensions = req_ext
distinguished_name = dn

[dn]
CN = AMP Proxy Wildcard

[req_ext]
subjectAltName = @alt_names

[alt_names]
# Valid wildcard SANs: single left-most label only (RFC 9525 / CA/B Forum).
# Generic entries like *, *.*, *.*.* are not valid DNS wildcards in X.509/TLS.
DNS.1 = localhost
DNS.2 = *.openai.com
DNS.3 = *.anthropic.com
DNS.4 = *.googleapis.com
DNS.5 = *.google.com
DNS.6 = *.stripe.com
DNS.7 = *.github.com
DNS.8 = *.httpbin.org
DNS.9 = *.amazonaws.com
DNS.10 = *.azure.com
DNS.11 = *.huggingface.co
