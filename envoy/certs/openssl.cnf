[req]
default_bits = 2048
prompt = no
default_md = sha256
req_extensions = req_ext
distinguished_name = dn

[dn]
CN = *

[req_ext]
subjectAltName = @alt_names

[alt_names]
DNS.1 = localhost
DNS.2 = httpbin.org
DNS.3 = *.httpbin.org
DNS.4 = api.openai.com
DNS.5 = *.openai.com
DNS.6 = api.github.com
DNS.7 = *.github.com
DNS.8 = *.stripe.com
